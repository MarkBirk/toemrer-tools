# ─── Frontend (miljøvariabler med VITE_ prefix) ──────
# Admin panel adgangskode (PÅKRÆVET for at /admin virker)
VITE_ADMIN_PASSWORD=din-admin-kode

# API URL (tom = same origin, sæt til backend URL hvis separat)
VITE_API_URL=

# ─── Backend / E-mail server ─────────────────────────
SMTP_HOST=smtpout.secureserver.net
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=din@email.dk
SMTP_PASS=dit-password
MAIL_FROM=din@email.dk

# Admin token til e-mail endpoint
ADMIN_TOKEN=skift-dette-til-noget-sikkert

# ─── Database (MySQL på Simply.com) ──────────────────
DB_HOST=mysql.simply.com
DB_USER=dit_brugernavn
DB_PASS=dit_password
DB_NAME=dit_dbnavn

# JWT secret til bruger-auth
JWT_SECRET=en-lang-random-string-mindst-32-tegn

# Server port
PORT=3001
